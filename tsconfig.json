{
    "compilerOptions": {
        "jsx": "react",
        "target": "ESNext",
       "module": "commonjs",
        "forceConsistentCasingInFileNames": true,
        "allowJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
             "@/lib/*": ["lib/*"]
        },
        "outDir": "dist",
        "moduleResolution": "node",
        "resolveJsonModule": true,
       "types": ["node"],
        "typeRoots": [
            "./src",
            "./src/types",
            "./node_modules/@types"
        ]
    },
    "include": [
        "src",
        "lib",
        "src/global.d.ts"
    ]
}
